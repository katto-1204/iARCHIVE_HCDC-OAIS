{
  "compilerOptions": {
    /* Standalone configuration: Inlined from tsconfig.base.json to resolve Vercel build issues */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    /* Strictness & Safety */
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": false,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "alwaysStrict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noEmitOnError": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    /* Vite & Environment */
    "noEmit": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "types": [
      "node",
      "vite/client"
    ],
    "customConditions": [
      "workspace"
    ],
    /* ignoreDeprecations removed — only valid for TypeScript ~5.0 */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@workspace/api-client-react": [
        "./src/lib/api-client-react.ts"
      ]
    }
  },
  "include": [
    "src/**/*",
    "api-server/scripts/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts"
  ]
}