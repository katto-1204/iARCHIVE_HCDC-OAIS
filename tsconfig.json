{
  "compilerOptions": {
    /* Standalone configuration: Inlined from tsconfig.base.json to resolve Vercel build issues */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    /* Strictness & Safety */
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": false,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "alwaysStrict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noEmitOnError": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    /* Vite & Environment */
    "noEmit": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "types": [
      "node",
      "vite/client"
    ],
    "customConditions": [
      "workspace"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@workspace/db": [
        "../../lib/db/src"
      ],
      "@workspace/db/*": [
        "../../lib/db/src/*"
      ],
      "drizzle-orm": [
        "../../lib/db/node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "../../lib/db/node_modules/drizzle-orm/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "seed.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "../../lib/api-client-react"
    },
    {
      "path": "../../lib/db"
    }
  ]
}