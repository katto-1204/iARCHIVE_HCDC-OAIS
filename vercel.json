{
  "buildCommand": "node node_modules/vite/bin/vite.js build --config vite.config.ts",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "{api-server/src/**,api-server/service-account.json,*.json}"
    }
  }
}
