{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": false,
    "types": ["node"],
    "baseUrl": "..",
    "typeRoots": ["../node_modules/@types"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["index.ts", "src/**/*.ts"]
}
