{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": false,
    "baseUrl": "..",
    "typeRoots": ["../node_modules/@types"],
    "types": ["node", "express", "cors", "jsonwebtoken", "express-serve-static-core"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.d.ts"]
}
