{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "noEmit": false,
    "types": ["node", "bcryptjs"],
    "baseUrl": "..",
    "typeRoots": ["../node_modules/@types"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["."]
}
